            <path d="M18.3362 18.339H15.6707V14.1622C15.6707 13.1662 15.6505 11.8845 14.2817 11.8845C12.892 11.8845 12.6797 12.9683 12.6797 14.0887V18.339H10.0142V9.75H12.5747V10.9207H12.6092C12.967 10.2457 13.837 9.53325 15.1367 9.53325C17.8375 9.53325 18.337 11.3108 18.337 13.6245V18.339H18.3362ZM7.00373 8.57475C6.14573 8.57475 5.45648 7.88025 5.45648 7.026C5.45648 6.1725 6.14648 5.47875 7.00373 5.47875C7.85873 5.47875 8.55173 6.1725 8.55173 7.026C8.55173 7.88025 7.85798 8.57475 7.00373 8.57475ZM8.34023 18.339H5.66723V9.75H8.34023V18.339ZM19.6697 3H4.32923C3.59498 3 3.00098 3.5805 3.00098 4.29675V19.7033C3.00098 20.4202 3.59498 21 4.32923 21H19.6675C20.401 21 21.001 20.4202 21.001 19.7033V4.29675C21.001 3.5805 20.401 3 19.6675 3H19.6697Z"/>
          </svg>
        </a>
        <a
          href="mailto:aida.ghergus96@gmail.com"
          aria-label="Email"
          class="social-icon-btn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
            <path d="m18.73 5.41l-1.28 1L12 10.46L6.55 6.37l-1.28-1A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64"/>
          </svg>
        </a>
      </div>
    </div>

    <LogoWall />

    <div class="flex flex-col lg:flex-row items-start gap-8 pt-2">
      <SkillsList client:load />
      <div class="flex justify-center w-full lg:w-auto">
        <Terminal client:load />
      </div>
    </div>
  </div>
</section>

<style is:global>
  .btn-primary {
    background: var(--sec);
    color: #060c18;
    padding: 10px 22px;
    border-radius: 8px;
    font-family: var(--mono, monospace);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-primary:hover { opacity: 0.85; transform: translateY(-2px); }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    padding: 10px 22px;
    border-radius: 8px;
    font-family: var(--mono, monospace);
    font-size: 13px;
    text-decoration: none;
    border: 1px solid var(--white-icon-tr);
    letter-spacing: 0.05em;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
  }
  .btn-secondary:hover { border-color: var(--sec); color: var(--sec); transform: translateY(-2px); }

  .social-icon-btn {
    color: var(--white-icon);
    transition: color 0.2s, background 0.2s, border-color 0.2s;
    border: 1px solid var(--white-icon-tr);
    padding: 10px;
    border-radius: 10px;
    background: rgba(11,18,35,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }
  .social-icon-btn:hover { color: var(--white); border-color: var(--sec); }

  .shiny-sec {
    background: linear-gradient(135deg, var(--sec) 25%, #c8e6ff 50%, var(--sec) 75%);
    background-size: 400% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 3s linear infinite;
  }
  @keyframes shine {
    0%   { background-position: 100% 50%; }
    30%, 70% { background-position: 0% 50%; }
  }

  /* Terminal styles */
  .terminal-box {
    background: var(--bg2, #0b1223);
    border: 1px solid var(--white-icon-tr);
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    max-width: 500px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }
  .terminal-bar {
    background: var(--bg3, #101a2e);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid var(--white-icon-tr);
  }
  .dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
  .terminal-title { font-size: 11px; color: var(--white-icon); margin-left: 6px; letter-spacing: 0.05em; font-family: var(--mono, monospace); }
  .terminal-body { padding: 16px 20px; font-family: var(--mono, monospace); font-size: 13px; line-height: 1.9; }
  .t-prompt { color: var(--sec); }
  .t-cmd    { color: var(--white); }
  .t-out    { color: var(--white-icon); display: block; }
  .t-green  { color: #4dff9a; display: block; }
  .t-cursor { display: inline-block; width: 8px; height: 13px; background: var(--sec); vertical-align: middle; margin-left: 2px; }
</style>