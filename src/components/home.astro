---
import Terminal from "../React/Terminal.tsx";
import LogoWall from "../components/logoWall.astro";
import SkillsList from "../React/SkillsList.tsx";
---

<section class="text-[var(--white)] mt-12 md:mt-0" id="home">
  <div class="max-w-5xl mx-auto space-y-8 md:py-36 pb-14">
    <div class="text-left space-y-4">
      <p class="text-sm text-[var(--white-icon)]" style="font-family: var(--mono); letter-spacing: 0.12em;">
        // java · backend · security · ai
      </p>
      <h1 class="text-[var(--white)] text-5xl md:text-7xl font-bold leading-none tracking-tight">
        Aida<br />Ghergus<span class="text-[var(--sec)]">.</span>
      </h1>
      <p class="text-xl md:text-2xl text-[var(--white-icon)] font-light">
        Building backend systems that <span class="text-[var(--sec)] shiny-sec">scale.</span>
      </p>
      <p class="text-base text-[var(--white-icon)] max-w-xl">
        Java developer with 8+ years of fullstack experience. Specialising in cloud architecture,
        distributed systems, and <strong class="text-[var(--white)] font-medium">AI integration</strong>.
      </p>
      <div class="flex gap-3 pt-2 flex-wrap">
        <a href="#projects" class="btn-primary">View work</a>
        <a href="#contact" class="btn-secondary">Get in touch</a>
      </div>
      <div class="flex justify-start gap-2 pt-1">
        <a
          target="_blank"
          href="https://github.com/gothsec"
          aria-label="GitHub"
          class="social-icon-btn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
