---
interface Project {
  title: string;
  description: string;
  tags: string[];
  link: string;
  preview?: string;
  status: string;
}

const projects: Project[] = [
  {
    title: "Conversational AI Agents",
    description:
      "Multi-channel AI agents that talk to your customers where they already are — WhatsApp, Instagram, SMS, or your website. Qualifies leads, answers questions, and handles first contact 24/7. Your business, always on.",
    tags: ["AI Agents", "WhatsApp", "Instagram", "SMS", "Chatbot"],
    link: "#contact",
    status: "Client project · ongoing",
  },
  {
    title: "Pericles · Legal AI Assistant",
    description:
      "AI assistant built for law firms — handles client intake, answers legal FAQs, and routes complex queries to the right lawyer. Reduces the time lawyers spend on repetitive first-contact interactions so they can focus on actual legal work.",
    tags: ["AI", "Legal Tech", "Chatbot", "Automation"],
    link: "#contact",
    status: "In development",
  },
  {
    title: "AI-Powered Backend Platform",
    description:
      "Production-grade backend handling real traffic for a B2B SaaS product. Java + Quarkus on AWS — Lambda, Cognito, S3, OpenAI integration, PostgreSQL, Docker, webhooks. This is the kind of system I build: reliable, scalable, and ready to grow with your business.",
    tags: ["Java", "Quarkus", "AWS", "OpenAI", "Docker", "PostgreSQL"],
    link: "https://smarttech247.com",
    status: "Production",
  },
  {
    title: "Fintech Wallet & Transactions",
    description:
      "Full-stack financial application with secure transfer operations. Java/Spring REST backend, ReactJS + Redux frontend. If you need a custom payment flow, transaction system, or financial dashboard — this is the kind of thing I deliver.",
    tags: ["Java", "Spring", "MongoDB", "ReactJS", "Redux"],
    link: "https://bitbucket.org/aidaghergus/workspace/projects/CLEAR",
    status: "Personal project",
  },
  {
    title: "Decentralised Exchange (Web3)",
    description:
      "Peer-to-peer bartering platform on Ethereum — no middleman, smart contract-enforced transactions, Metamask integration. Need blockchain or Web3 on your product? Done it.",
    tags: ["Solidity", "Truffle", "web3js", "ReactJS", "Ethereum"],
    link: "https://bitbucket.org/aidaghergus/workspace/projects/BAR",
    status: "MSc project · 2020",
  },
  {
    title: "AI Content Intelligence Tool",
    description:
      "Automated pipeline that crawls the web, pulls social signals, and uses AI to score and rank content quality — turning messy data into actionable insights. An early example of what I still build: systems that think so you don't have to.",
    tags: ["Java", "Spring", "IBM Watson", "MySQL", "ReactJS"],
    link: "https://bitbucket.org/aidaghergus/workspace/projects/SER",
    status: "Personal project · 2018",
  },
];
---

<section id="projects" class="py-12 border-t border-[var(--white-icon-tr)] text-[var(--white)]">
  <div class="max-w-5xl mx-auto">
    <p class="text-sm text-[var(--sec)] mb-2" style="font-family: var(--mono); letter-spacing: 0.12em; text-transform: uppercase;">projects</p>
    <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-10">
      Selected <span class="shiny-sec">work.</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        projects.map((project) => (
          <div class="project-card group">
            <div class="flex flex-wrap gap-2 mb-3">
              {project.tags.map((tag) => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
            <h3 class="text-xl font-semibold mb-2 text-[var(--white)]">{project.title}</h3>
            <p class="text-sm text-[var(--white-icon)] leading-relaxed flex-1">{project.description}</p>
            <div class="flex items-center justify-between mt-4 pt-4 border-t border-[var(--white-icon-tr)]">
              <span class="text-xs text-[var(--white-icon)]" style="font-family: var(--mono);">{project.status}</span>
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-[var(--sec)] hover:underline flex items-center gap-1 transition-all duration-200"
                style="font-family: var(--mono);"
              >
                view →
              </a>
            </div>
          </div>
        ))
      }
    </div>

    <a
      target="_blank"
      href="https://bitbucket.org/aidaghergus/workspace/repositories"
      class="w-full flex items-center justify-center gap-2 mt-8 text-[var(--white-icon)] hover:text-[var(--white)] transition duration-300 border border-[var(--white-icon-tr)] p-3 rounded-full hover:border-[var(--sec)] hover:scale-105"
      style="background: rgba(11,18,35,0.6);"
    >
      <span class="md:text-lg text-base">More on Bitbucket</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
        <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .project-card {
    background: var(--bg2);
    border: 1px solid var(--white-icon-tr);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .project-card:hover {
    border-color: var(--white);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }
  .project-tag {
    font-family: var(--mono, monospace);
    font-size: 10px;
    color: var(--white);
    background: var(--sec-dim);
    border: 1px solid var(--white-icon-tr);
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.04em;
  }
</style>