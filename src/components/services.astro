---

<section id="services" class="py-12 border-t border-[var(--white-icon-tr)] text-[var(--white)] scroll-mt-24">
  <div class="max-w-5xl mx-auto">
    <p class="section-eyebrow">services</p>
    <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      What we build<span class="text-[var(--sec)]">.</span>
    </h2>
    <p class="text-[var(--white-icon)] max-w-xl mb-10 leading-relaxed">
      aidware is founder-led: every project is scoped, built and shipped by the
      engineer you talk to on day one.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        services.map((service, i) => (
          <div class="service-card">
            <div class="service-icon" aria-hidden="true">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="text-lg font-semibold mb-1.5">
              {i === services.length - 1 ? (
                <a href="/contact" class="hover:underline decoration-[var(--sec)] underline-offset-4">{service.title}</a>
              ) : (
                service.title
              )}
            </h3>
            <p class="text-sm text-[var(--white-icon)] leading-relaxed">{service.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-card {
    background: var(--bg2);
    border: 1px solid var(--white-icon-tr);
    border-radius: 12px;
    padding: 24px;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .service-card:hover {
    border-color: var(--white);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }
  .service-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: var(--sec-dim);
    border: 1px solid var(--white-icon-tr);
    color: var(--sec2);
    margin-bottom: 14px;
  }
</style>
