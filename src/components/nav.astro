---
interface NavItem {
  label: string;
  href: string;
  icon: string;
}

const navItems: NavItem[] = [
  {
    label: "Home",
    href: "/#home",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M21 20C21 20.5523 20.5523 21 20 21H4C3.44772 21 3 20.5523 3 20V9.48907C3 9.18048 3.14247 8.88917 3.38606 8.69972L11.3861 2.47749C11.7472 2.19663 12.2528 2.19663 12.6139 2.47749L20.6139 8.69972C20.8575 8.88917 21 9.18048 21 9.48907V20ZM19 19V9.97815L12 4.53371L5 9.97815V19H19Z"></path></svg>`,
  },
  {
    label: "Services",
    href: "/#services",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M5.32943 3.27158C6.56252 2.8332 7.9923 3.10749 8.97927 4.09446C10.1002 5.21537 10.3019 6.90741 9.58447 8.23385L20.293 18.9437L18.8788 20.3579L8.16982 9.64875C6.84325 10.3669 5.15069 10.1654 4.02952 9.04421C3.04227 8.05696 2.7681 6.62665 3.20701 5.39332L5.44373 7.63C6.02952 8.21578 6.97927 8.21578 7.56505 7.63C8.15084 7.04421 8.15084 6.09446 7.56505 5.50868L5.32943 3.27158ZM15.6968 5.15512L18.8788 3.38735L20.293 4.80157L18.5252 7.98351L16.7574 8.33706L14.6361 10.4584L13.2219 9.04421L15.3432 6.92289L15.6968 5.15512ZM8.97927 13.2868L10.3935 14.701L5.09018 20.0043C4.69966 20.3948 4.06649 20.3948 3.67597 20.0043C3.31462 19.6429 3.28686 19.0742 3.59271 18.6817L3.67597 18.5901L8.97927 13.2868Z"></path></svg>`,
  },
  {
    label: "Projects",
    href: "/#work",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M4 5V19H20V7H11.5858L9.58579 5H4ZM12.4142 5H21C21.5523 5 22 5.44772 22 6V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V4C2 3.44772 2.44772 3 3 3H10.4142L12.4142 5Z"></path></svg>`,
  },
  {
    label: "Studio",
    href: "/#studio",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M4 22C4 17.5817 7.58172 14 12 14C16.4183 14 20 17.5817 20 22H18C18 18.6863 15.3137 16 12 16C8.68629 16 6 18.6863 6 22H4ZM12 13C8.685 13 6 10.315 6 7C6 3.685 8.685 1 12 1C15.315 1 18 3.685 18 7C18 10.315 15.315 13 12 13ZM12 11C14.21 11 16 9.21 16 7C16 4.79 14.21 3 12 3C9.79 3 8 4.79 8 7C8 9.21 9.79 11 12 11Z"></path></svg>`,
  },
  {
    label: "Contact",
    href: "/#contact",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M21.7267 2.95694L16.2734 22.0432C16.1225 22.5716 15.7979 22.5956 15.5563 22.1126L11 13L1.9229 9.36919C1.41322 9.16532 1.41953 8.86022 1.95695 8.68108L21.0432 2.31901C21.5716 2.14285 21.8747 2.43866 21.7267 2.95694ZM19.0353 5.09647L6.81221 9.17085L12.4488 11.4255L15.4895 17.5068L19.0353 5.09647Z"></path></svg>`,
  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const isActive = (href: string) => currentPath === "/" && href === "/#home";
---

<div class="flex justify-center w-full">
  <nav
    id="main-nav"
    class="fixed left-1/2 -translate-x-1/2 z-[100] bg-[var(--background)] border border-[var(--white-icon-tr)] backdrop-blur-xl md:top-6 md:bottom-auto bottom-0 w-auto"
    aria-label="Main navigation"
  >
    <div class="flex justify-center items-center p-3 md:px-10">
      <ul
        class="flex w-full md:w-auto justify-between md:justify-center md:gap-10 gap-4"
      >
        {
          navItems.map((item) => (
            <li class="flex-1 md:flex-none">
              <a
                href={item.href}
                class:list={[
                  "flex flex-col items-center gap-1 text-[var(--white-icon)] transition-colors text-xs md:text-base relative group",
                  { active: isActive(item.href) },
                ]}
                aria-current={isActive(item.href) ? "page" : undefined}
              >
                <div class="absolute left-1/2 -translate-x-1/2 -bottom-2 w-1.5 h-1.5 rounded-full transition-all duration-300 scale-0 opacity-0 bg-[var(--sec)] nav-indicator hidden md:block" />
                <span class="md:hidden flex items-center justify-center w-6 h-6">
                  <Fragment set:html={item.icon} />
                </span>
                <span class="hidden md:inline-block">{item.label}</span>
                <span class="md:hidden">{item.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</div>

<style>
  nav {
    transform: translateX(-50%);
    background-color: rgba(245, 243, 239, 0.85);
    border-color: var(--white-icon-tr);
    border-radius: 9999px;
    box-shadow: 0 2px 16px rgba(196, 180, 154, 0.15);
    transition:
      background-color 0.3s ease,
      border-radius 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  nav.scrolling {
    background-color: rgba(245, 243, 239, 0.95);
    border-color: var(--sec);
    box-shadow: 0 4px 24px rgba(196, 180, 154, 0.25);
    border-radius: 9999px;
  }

  nav a.active .nav-indicator {
    transform: translateX(-50%) scale(1);
    opacity: 1;
  }

  nav a.active,
  nav a:hover {
    color: var(--white);
  }

  @media (max-width: 767px) {
    nav {
      width: 100% !important;
      transform: translateX(-50%);
      bottom: 0;
      left: 50%;
      position: fixed;
      border-radius: 1rem 1rem 0 0;
      border-color: var(--white-icon-tr);
    }

    nav.scrolling {
      border-radius: 1rem 1rem 0 0;
      background-color: rgba(245, 243, 239, 0.95);
    }
  }
</style>

<style is:global>
  @media (max-width: 767px) {
    body {
      padding-bottom: 80px;
    }
  }
</style>

<script>
  const nav = document.getElementById("main-nav");
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>("#main-nav a")
  );

  const sectionLinks = navLinks.flatMap((link) => {
    const id = new URL(link.href).hash.slice(1);
    const section = id ? document.getElementById(id) : null;
    return section ? [{ link, section }] : [];
  });

  function setActive(active: HTMLAnchorElement | undefined) {
    navLinks.forEach((link) => {
      link.classList.toggle("active", link === active);
      if (link === active) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  }

  let rafId: number | null = null;

  function updateNav() {
    nav?.classList.toggle("scrolling", window.scrollY > 0);

    if (sectionLinks.length) {
      let current = sectionLinks[0];
      for (const item of sectionLinks) {
        if (item.section.getBoundingClientRect().top <= 150) {
          current = item;
        }
      }
      setActive(current.link);
    }
    rafId = null;
  }

  window.addEventListener(
    "scroll",
    () => {
      if (!rafId) {
        rafId = requestAnimationFrame(updateNav);
      }
    },
    { passive: true }
  );
  updateNav();
</script>