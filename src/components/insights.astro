---
---

<div class="insights-section">
  <div class="insights-inner">
    <p class="insights-label">credentials & beyond</p>
    <h2 class="insights-title">Beyond the code<span style="color: var(--sec)">.</span></h2>

    <div class="insights-grid">

      <!-- Conference talk — tall card col 1 -->
      <div class="icard icard-dark icard-tall">
        <div>
          <div class="icard-eyebrow">Conference · Public Speaking</div>
          <div class="icard-title">Conference Talk</div>
          <div class="icard-body">
            Speaker at a tech conference — sharing insights on software engineering, AI integration, and building systems that work in the real world.
          </div>
        </div>
        <div class="video-wrapper">
          <iframe
            src="https://www.youtube.com/embed/slGJ7YZxKJQ"
            title="Conference Talk"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
        <div class="icard-footer" style="margin-top: 16px;">
          <div class="icard-dots">
            <div class="icard-dot active"></div>
            <div class="icard-dot"></div>
          </div>
          <a href="https://www.youtube.com/watch?v=slGJ7YZxKJQ" target="_blank" class="icard-link icard-link-light" aria-label="Watch on YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"/></svg>
          </a>
        </div>
      </div>

      <!-- ML Certificate -->
      <div class="icard icard-beige">
        <div>
          <div class="icard-eyebrow">Certificate · ITSchool</div>
          <div class="icard-title">Machine Learning</div>
          <div class="icard-body">
            Supervised & unsupervised learning, neural networks, and practical ML applications with Python.
          </div>
        </div>
        <div class="icard-footer">
          <div class="icard-tags-row">
            <span class="icard-tag">Python</span>
            <span class="icard-tag">ML</span>
          </div>
          <a href="/diploma-ml.pdf" target="_blank" class="icard-link" aria-label="View certificate">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"/></svg>
          </a>
        </div>
      </div>

      <!-- Oracle certifications -->
      <div class="icard icard-beige">
        <div>
          <div class="icard-eyebrow">Certification · Oracle</div>
          <div class="icard-title">SQL & PL/SQL</div>
          <div class="icard-body">
            Oracle certified in both SQL and PL/SQL — relational data modeling, advanced queries, stored procedures, triggers, and performance tuning.
          </div>
        </div>
        <div class="icard-footer">
          <div class="icard-tags-row">
            <span class="icard-tag">Oracle</span>
            <span class="icard-tag">SQL</span>
            <span class="icard-tag">PL/SQL</span>
          </div>
          <div class="icard-dots">
            <div class="icard-dot active"></div>
            <div class="icard-dot"></div>
          </div>
        </div>
      </div>

      <!-- She Leads Tomorrow -->
      <div class="icard icard-beige">
        <div>
          <div class="icard-eyebrow">Leadership · She Leads Tomorrow</div>
          <div class="icard-title">Leadership Programme</div>
          <div class="icard-body">
            Completed the She Leads Tomorrow leadership programme — developing strategic thinking, communication, and leadership skills for women in tech.
          </div>
        </div>
        <div class="icard-footer">
          <div class="icard-tags-row">
            <span class="icard-tag">Leadership</span>
            <span class="icard-tag">WomenInTech</span>
          </div>
          <div class="icard-dots">
            <div class="icard-dot active"></div>
            <div class="icard-dot"></div>
          </div>
        </div>
      </div>

      <!-- Ajungem Mari volunteering -->
      <div class="icard icard-dark">
        <div>
          <div class="icard-eyebrow">Volunteering · Ajungem Mari</div>
          <div class="icard-title">Volunteer</div>
          <div class="icard-body">
            Volunteer at Ajungem Mari — a Romanian NGO that mentors young people from disadvantaged backgrounds, helping them discover their potential and access better opportunities.
          </div>
        </div>
        <div class="icard-footer">
          <div class="icard-tags-row">
            <span class="icard-tag icard-tag-light">Mentoring</span>
            <span class="icard-tag icard-tag-light">NGO</span>
          </div>
          <div class="icard-dots">
            <div class="icard-dot active"></div>
            <div class="icard-dot"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .insights-section {
    background: var(--bg3);
    border-top: 1px solid var(--white-icon-tr);
    border-bottom: 1px solid var(--white-icon-tr);
    padding: 80px 0;
    width: 100vw;
    margin-left: calc(-1 * (100vw - 100%) / 2);
    margin-right: calc(-1 * (100vw - 100%) / 2);
  }
  .insights-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .insights-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white-icon);
    margin-bottom: 8px;
  }
  .insights-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }
  .insights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .icard {
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    min-height: 240px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 24px 22px 20px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    cursor: default;
  }
  .icard:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,0.12); }

  .icard-beige {
    background: var(--sec);
    color: #1a1610;
  }
  .icard-beige .icard-tag { border-color: rgba(26,22,16,0.3); color: #1a1610; }
  .icard-beige .icard-eyebrow { color: rgba(26,22,16,0.6); }
  .icard-beige .icard-dots .icard-dot { background: #1a1610; }

  .icard-dark {
    background: #111111;
    border: 1px solid #222;
    color: #f0ece4;
  }
  .icard-dark .icard-eyebrow { color: var(--sec); opacity: 1; }
  .icard-dark .icard-title { color: #f0ece4; }
  .icard-dark .icard-body { color: #888; }
  .icard-dark .icard-dot { background: var(--sec); }

  .icard-eyebrow {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 12px;
    opacity: 0.6;
  }
  .icard-title {
    font-size: 15px;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .icard-body {
    font-size: 13px;
    line-height: 1.7;
    opacity: 0.75;
    flex: 1;
    margin-bottom: 14px;
  }
  .icard-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }
  .icard-tags-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .icard-tag {
    font-family: var(--mono);
    font-size: 10px;
    border: 1px solid;
    border-radius: 20px;
    padding: 3px 10px;
    letter-spacing: 0.04em;
  }
  .icard-tag-light {
    border-color: rgba(196,180,154,0.4);
    color: var(--sec);
  }
  .icard-dots { display: flex; gap: 5px; }
  .icard-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: currentColor; opacity: 0.25;
  }
  .icard-dot.active { opacity: 0.8; }

  .icard-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid rgba(26,22,16,0.3);
    color: #1a1610;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .icard-link:hover { background: rgba(26,22,16,0.1); }

  .icard-link-light {
    border-color: rgba(196,180,154,0.4);
    color: var(--sec);
  }
  .icard-link-light:hover { background: rgba(196,180,154,0.1); }

  .video-wrapper {
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 16/9;
    width: 100%;
  }
  .video-wrapper iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  .icard-tall { grid-row: span 2; }

  @media (max-width: 900px) {
    .insights-grid { grid-template-columns: 1fr 1fr; }
    .icard-tall { grid-row: span 1; }
    .insights-inner { padding: 0 24px; }
  }
  @media (max-width: 600px) {
    .insights-grid { grid-template-columns: 1fr; }
    .insights-section { padding: 60px 0; }
  }
</style>