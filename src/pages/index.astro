---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav.astro";
import Home from "@/components/home.astro";
import Services from "@/components/services.astro";
import ProjectGrid from "@/components/projectGrid.astro";
import Studio from "@/components/studio.astro";
import Footer from "@/components/footer.astro";
import { projects } from "@/data/projects";

const featured = projects.filter((p) => p.featured);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "aidware",
  url: "https://www.aidware.dev",
  description:
    "aidware builds production-ready AI applications, backend systems and tailored software for legal and real estate businesses.",
  email: "aida@aidware.dev",
  founder: {
    "@type": "Person",
    name: "Aida Ghergus",
    jobTitle: "Senior Backend Engineer",
    sameAs: [
      "https://github.com/aidaghergus",
      "https://www.linkedin.com/in/aidaghergus/",
    ],
  },
  areaServed: ["Romania", "Spain", "Remote"],
};
---

<Layout
  title="aidware — AI Applications & Backend Development"
  description="aidware builds production-ready AI applications, backend systems and tailored software for legal and real estate businesses."
  structuredData={structuredData}
>
  <Nav />
  <main>
    <Home />
    <Services />

    <section id="work" class="py-12 border-t border-[var(--white-icon-tr)] text-[var(--white)]">
      <div class="max-w-5xl mx-auto">
        <p class="section-eyebrow">projects</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-10">
          Selected <span class="shiny-sec">work.</span>
        </h2>
        <ProjectGrid projects={featured} />
        <div class="flex justify-center mt-8">
          <a href="/projects" class="btn-secondary">
            View all projects
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4" aria-hidden="true">
              <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <Studio />

    <section class="py-12 border-t border-[var(--white-icon-tr)]">
      <div class="max-w-5xl mx-auto">
        <div class="rounded-2xl border border-[var(--sec)] bg-[var(--bg2)] p-8 md:p-12 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-[var(--white)] mb-2">
              Have a project in mind<span class="text-[var(--sec)]">?</span>
            </h2>
            <p class="text-[var(--white-icon)]">Tell me what you are trying to build.</p>
          </div>
          <a href="/contact" class="btn-primary flex-shrink-0">Discuss a project</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
