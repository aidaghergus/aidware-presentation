---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav.astro";
import Footer from "@/components/footer.astro";
import { summary, skillGroups } from "@/data/profile";

interface CvJob {
  role: string;
  company: string;
  period: string;
  location: string;
  intro?: string;
  points: string[];
}

const jobs: CvJob[] = [
  {
    role: "Founder | Backend & AI Engineer",
    company: "aidware",
    period: "07/2025 – Present",
    location: "Remote",
    intro: "Building production-ready AI applications for legal and real estate clients.",
    points: [
      "Built AI-powered applications for multiple freelance clients across legal and real estate domains.",
      "Sole engineer responsible for the end-to-end development of Pericles, a multi-agent AI platform for Spanish lawyers, built with JavaScript, Firebase and Vertex AI (Gemini).",
      "Evaluated and integrated multiple LLM providers, including Claude and Gemini.",
      "Developed AI-powered chatbots for Spanish real estate platforms.",
      "Implemented CI/CD pipelines using GitHub Actions.",
      "Developed Python automation scripts for document processing and information extraction.",
    ],
  },
  {
    role: "Full Stack Developer",
    company: "Qualysoft Romania (Smarttech247)",
    period: "05/2023 – 06/2025",
    location: "Remote",
    points: [
      "Built a Java + Quarkus application and AWS Lambda functions from scratch, deployed on AWS.",
      "Worked primarily on backend development while also contributing to frontend features using React.",
      "Used PostgreSQL, Flyway, Docker, OpenAI and AWS services including Lambda, Cognito, CloudWatch, S3 and Amazon Q.",
      "Integrated webhooks and third-party APIs for data extraction and automation.",
      "Performed unit and integration testing using JUnit 5, Mockito and WireMock.",
      "Collaborated remotely with a multicultural team based in Cork, Ireland, working entirely in English.",
    ],
  },
  {
    role: "Java Developer",
    company: "Cognyte Romania",
    period: "06/2021 – 05/2023",
    location: "Bucharest, Romania",
    points: [
      "Developed features and resolved complex production issues in a large-scale Java monolith deployed on JBoss, alongside Spring Boot microservices.",
      "Worked extensively with Apache Kafka to debug and troubleshoot event-driven pipelines.",
      "Improved production reliability through debugging and performance analysis across REST, TCP and Kafka communication.",
      "Worked with Sybase and Elasticsearch.",
      "Delivered technical trainings and onboarded new engineers.",
    ],
  },
  {
    role: "Full Stack Developer",
    company: "METRO SYSTEMS Romania",
    period: "01/2018 – 06/2021",
    location: "Bucharest, Romania",
    points: [
      "Developed backend applications using Java and Spring, deployed in Docker containers orchestrated by Kubernetes, on both private and public cloud (GCP).",
      "Developed frontend applications using Angular and React.",
      "Used Elasticsearch for log management; monitored applications with Kibana and Grafana; CI/CD with Jenkins and Ansible.",
      "Worked with SQL and NoSQL databases such as MariaDB and Cassandra.",
      "Awarded Third Prize at Innovation Days for a team IoT project.",
    ],
  },
  {
    role: "Full Stack Developer Intern",
    company: "METRO SYSTEMS Romania",
    period: "02/2017 – 01/2018",
    location: "Bucharest, Romania",
    points: [
      "Worked in an Agile team at a multinational company, learning middleware principles and IBM WebSphere.",
      "Developed applications using Java, Camel and JBoss.",
      "Second Prize in Security Day, an internal contest on IT security fundamentals.",
    ],
  },
];

interface CvProject {
  title: string;
  year: string;
  description: string;
  tech: string[];
  link?: string;
}

const cvProjects: CvProject[] = [
  {
    title: "AidArch",
    year: "2025",
    description:
      "AI-powered land analysis platform that gathers and organizes public information about a land parcel for early-stage evaluation.",
    tech: ["AI", "Data Aggregation"],
  },
  {
    title: "Land Feasibility ML",
    year: "2025",
    description:
      "Residual land value calculator on the Madrid Real Estate Kaggle dataset. Linear Regression, Random Forest and XGBoost, evaluated with MAE and R².",
    tech: ["Python", "Machine Learning", "XGBoost"],
  },
  {
    title: "GenAI Jobs",
    year: "2025",
    description:
      "GenAI-powered application that parses job postings and extracts role details and required technologies. Ongoing side project.",
    tech: ["Python", "Streamlit"],
    link: "https://genai-jobs.streamlit.app",
  },
  {
    title: "Clear Wallet",
    year: "2021",
    description:
      "Wallet application supporting transfer operations from a web interface.",
    tech: ["Java", "Spring", "MongoDB", "React", "Redux", "Ant Design"],
    link: "https://bitbucket.org/aidaghergus/workspace/projects/CLEAR",
  },
  {
    title: "Blockchain Barter Exchange",
    year: "2020",
    description:
      "Hybrid decentralized application for secure online bartering, using blockchain to ensure transaction integrity.",
    tech: ["Solidity", "Truffle", "web3.js", "React", "MetaMask"],
    link: "https://bitbucket.org/aidaghergus/workspace/projects/BAR",
  },
  {
    title: "Media Analysis Platform",
    year: "2018",
    description:
      "Indexing and statistical analysis of online media content — ranks series and films on multiple indicators using IBM Watson and Crawler4j.",
    tech: ["Java", "Spring", "IBM Watson", "MySQL", "React"],
    link: "https://bitbucket.org/aidaghergus/workspace/projects/SER",
  },
];

const certificates = [
  "Machine Learning Course – IT School",
  "Leadership Program – She Leads Tomorrow",
  "ReactJS Fundamentals + Advanced",
  "Oracle Database Design and SQL",
  "Oracle Database PL/SQL Developer",
  "ECDL / ICDL",
  "CISCO – IT Essentials",
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Aida Ghergus",
  jobTitle: "Senior Software Engineer",
  url: "https://www.aidware.dev/cv",
  email: "aida.ghergus96@gmail.com",
  sameAs: [
    "https://github.com/aidaghergus",
    "https://www.linkedin.com/in/aidaghergus/",
  ],
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Bucharest University of Economic Studies",
  },
};
---

<Layout
  title="Aida Ghergus — Senior Software Engineer · CV"
  description="CV of Aida Ghergus, Senior Software Engineer with 8+ years of experience in backend systems, distributed applications and AI-powered products."
  ogType="profile"
  structuredData={structuredData}
>
  <Nav />
  <main class="cv-page pt-24 md:pt-32 pb-16">
    <div class="max-w-[1080px] mx-auto">

      <div class="no-print flex justify-end mb-4">
        <button id="print-cv" class="btn-secondary" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4" aria-hidden="true"><path d="M7 17H17V22H7V17ZM19 20V15H5V20H3C2.44772 20 2 19.5523 2 19V8C2 7.44772 2.44772 7 3 7H21C21.5523 7 22 7.44772 22 8V19C22 19.5523 21.5523 20 21 20H19ZM5 9V11H8V9H5ZM9 19H15V20H9V19ZM9 2H19V5H9V2Z"/></svg>
          Print / Save as PDF
        </button>
      </div>

      <div class="cv-sheet">

        <!-- ============ SIDEBAR ============ -->
        <aside class="cv-side">
          <div class="cv-side-inner">
            <img
              src="/me2.png"
              alt="Aida Ghergus"
              width="112"
              height="112"
              class="cv-portrait"
            />
            <h1 class="cv-side-name">Aida Ghergus<span class="cv-accent">.</span></h1>
            <p class="cv-side-role">Senior Software Engineer</p>
            <p class="cv-tagline">backend · ai · cloud</p>

            <hr class="cv-rule" />

            <ul class="cv-contact">
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 20.8995L16.9497 15.9497C19.6834 13.2161 19.6834 8.78392 16.9497 6.05025C14.2161 3.31658 9.78392 3.31658 7.05025 6.05025C4.31658 8.78392 4.31658 13.2161 7.05025 15.9497L12 20.8995ZM12 23.7279L5.63604 17.364C2.12132 13.8492 2.12132 8.15076 5.63604 4.63604C9.15076 1.12132 14.8492 1.12132 18.364 4.63604C21.8787 8.15076 21.8787 13.8492 18.364 17.364L12 23.7279ZM12 13C13.1046 13 14 12.1046 14 11C14 9.89543 13.1046 9 12 9C10.8954 9 10 9.89543 10 11C10 12.1046 10.8954 13 12 13Z"/></svg>
                <span>Bucharest, Romania<br />Marbella, Spain</span>
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m18.73 5.41l-1.28 1L12 10.46L6.55 6.37l-1.28-1A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64"/></svg>
                <a href="mailto:aida.ghergus96@gmail.com">aida.ghergus96@gmail.com</a>
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.0607 8.11097L14.4749 9.52518C17.2086 12.2589 17.2086 16.691 14.4749 19.4247L14.1214 19.7782C11.3877 22.5119 6.95555 22.5119 4.22188 19.7782C1.48821 17.0446 1.48821 12.6124 4.22188 9.87874L5.6361 11.293C3.68348 13.2456 3.68348 16.4114 5.6361 18.364C7.58872 20.3166 10.7545 20.3166 12.7072 18.364L13.0607 18.0105C15.0133 16.0578 15.0133 12.892 13.0607 10.9394L11.6465 9.52518L13.0607 8.11097ZM19.7782 14.1214L18.364 12.7072C20.3166 10.7545 20.3166 7.58872 18.364 5.6361C16.4114 3.68348 13.2456 3.68348 11.293 5.6361L10.9394 5.98965C8.98678 7.94227 8.98678 11.1081 10.9394 13.0607L12.3536 14.4749L10.9394 15.8891L9.52518 14.4749C6.79151 11.7413 6.79151 7.30911 9.52518 4.57544L9.87874 4.22188C12.6124 1.48821 17.0446 1.48821 19.7782 4.22188C22.5119 6.95555 22.5119 11.3877 19.7782 14.1214Z"/></svg>
                <a href="https://www.aidware.dev">aidware.dev</a>
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"/></svg>
                <a href="https://github.com/aidaghergus" target="_blank" rel="noopener noreferrer">github.com/aidaghergus</a>
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.3362 18.339H15.6707V14.1622C15.6707 13.1662 15.6505 11.8845 14.2817 11.8845C12.892 11.8845 12.6797 12.9683 12.6797 14.0887V18.339H10.0142V9.75H12.5747V10.9207H12.6092C12.967 10.2457 13.837 9.53325 15.1367 9.53325C17.8375 9.53325 18.337 11.3108 18.337 13.6245V18.339H18.3362ZM7.00373 8.57475C6.14573 8.57475 5.45648 7.88025 5.45648 7.026C5.45648 6.1725 6.14648 5.47875 7.00373 5.47875C7.85873 5.47875 8.55173 6.1725 8.55173 7.026C8.55173 7.88025 7.85798 8.57475 7.00373 8.57475ZM8.34023 18.339H5.66723V9.75H8.34023V18.339ZM19.6697 3H4.32923C3.59498 3 3.00098 3.5805 3.00098 4.29675V19.7033C3.00098 20.4202 3.59498 21 4.32923 21H19.6675C20.401 21 21.001 20.4202 21.001 19.7033V4.29675C21.001 3.5805 20.401 3 19.6675 3H19.6697Z"/></svg>
                <a href="https://www.linkedin.com/in/aidaghergus/" target="_blank" rel="noopener noreferrer">linkedin.com/in/aidaghergus</a>
              </li>
            </ul>

            <hr class="cv-rule" />

            <div class="cv-skills">
              {
                skillGroups.map((group) => (
                  <div class="cv-skill-group">
                    <p class="cv-side-label">{group.title}</p>
                    <ul class="cv-chips">
                      {group.items.map((item) => (
                        <li class="cv-chip">{item}</li>
                      ))}
                    </ul>
                  </div>
                ))
              }
            </div>

            <hr class="cv-rule" />

            <div>
              <p class="cv-side-label">Spoken languages</p>
              <ul class="cv-langs">
                <li><span>English</span><span class="cv-muted">Full professional</span></li>
                <li><span>Spanish</span><span class="cv-muted">Limited working</span></li>
              </ul>
            </div>
          </div>
        </aside>

        <!-- ============ MAIN COLUMN ============ -->
        <div class="cv-main">

          <!-- Page 1: identity, summary, recent experience -->
          <div class="cv-pg cv-pg1">
            <!-- Summary -->
            <section class="cv-section cv-block">
              <p class="cv-eyebrow">// curriculum vitae</p>
              <h2 class="cv-h">Summary<span class="cv-accent">.</span></h2>
              <p class="cv-body">{summary}</p>
            </section>

            <!-- Experience (most recent) -->
            <section class="cv-section">
              <h2 class="cv-h">Experience<span class="cv-accent">.</span></h2>
              <div class="cv-timeline">
                {
                  jobs.slice(0, 3).map((job) => (
                    <article class="cv-job cv-block">
                      <span class="cv-timeline-dot" aria-hidden="true" />
                      <div class="cv-job-head">
                        <h3 class="cv-job-company">{job.company}</h3>
                        <p class="cv-job-meta">{job.period} · {job.location}</p>
                      </div>
                      <p class="cv-job-role">{job.role}</p>
                      {job.intro && <p class="cv-job-intro">{job.intro}</p>}
                      <ul class="cv-points">
                        {job.points.map((point) => (
                          <li>{point}</li>
                        ))}
                      </ul>
                    </article>
                  ))
                }
              </div>
            </section>
          </div>

          <!-- Page 2: earlier experience + projects -->
          <div class="cv-pg cv-pg2">
            <div class="cv-compact" aria-hidden="true">
              <p class="cc-id">Aida Ghergus <span>— Senior Software Engineer</span></p>
              <p class="cc-site">aidware.dev</p>
            </div>

            <section class="cv-section cv-exp-cont">
              <p class="cv-cont-label">experience — continued</p>
              <div class="cv-timeline">
                {
                  jobs.slice(3).map((job) => (
                    <article class="cv-job cv-block">
                      <span class="cv-timeline-dot" aria-hidden="true" />
                      <div class="cv-job-head">
                        <h3 class="cv-job-company">{job.company}</h3>
                        <p class="cv-job-meta">{job.period} · {job.location}</p>
                      </div>
                      <p class="cv-job-role">{job.role}</p>
                      {job.intro && <p class="cv-job-intro">{job.intro}</p>}
                      <ul class="cv-points">
                        {job.points.map((point) => (
                          <li>{point}</li>
                        ))}
                      </ul>
                    </article>
                  ))
                }
              </div>
            </section>

            <!-- Speaking -->
            <section class="cv-section cv-block">
              <h2 class="cv-h">Speaking<span class="cv-accent">.</span></h2>
              <div class="cv-speaking">
                <div class="cv-job-head">
                  <h3 class="cv-job-company">Speaker · Codecamp Romania</h3>
                  <p class="cv-job-meta">2021</p>
                </div>
                <p class="cv-job-role">How to Write Code 2x Faster</p>
                <p class="cv-body" style="margin-top: 4px;">
                  Presentation on IntelliJ productivity and developer workflow.
                </p>
              </div>
            </section>

            <!-- Projects -->
            <section class="cv-section">
              <h2 class="cv-h">Projects<span class="cv-accent">.</span></h2>
              <div class="cv-projects">
                {
                  cvProjects.map((project) => (
                    <article class="cv-project cv-block">
                      <div class="cv-project-head">
                        <h3>{project.title}</h3>
                        <span class="cv-project-year">{project.year}</span>
                      </div>
                      <p class="cv-project-desc">{project.description}</p>
                      <ul class="cv-chips">
                        {project.tech.map((t) => (
                          <li class="cv-chip">{t}</li>
                        ))}
                      </ul>
                      {project.link && (
                        <a href={project.link} target="_blank" rel="noopener noreferrer" class="cv-project-link">
                          {project.link.replace("https://", "").replace("/workspace/projects/", "/…/")}
                        </a>
                      )}
                    </article>
                  ))
                }
              </div>
            </section>
          </div>

          <!-- Page 3: speaking, education, certificates, volunteering -->
          <div class="cv-pg cv-pg3">
            <div class="cv-compact" aria-hidden="true">
              <p class="cc-id">Aida Ghergus <span>— Senior Software Engineer</span></p>
              <p class="cc-site">aidware.dev</p>
            </div>

            <!-- Education -->
            <section class="cv-section cv-block">
              <h2 class="cv-h">Education<span class="cv-accent">.</span></h2>
              <div class="cv-edu">
                <div class="cv-edu-item">
                  <h3>IT&C Security Master's Degree</h3>
                  <p>Bucharest University of Economic Studies</p>
                  <p class="cv-job-meta">2018 – 2020</p>
                </div>
                <div class="cv-edu-item">
                  <h3>BSc in Cybernetics, Statistics and Informatics</h3>
                  <p>Bucharest University of Economic Studies</p>
                  <p class="cv-job-meta">2015 – 2018</p>
                </div>
              </div>
            </section>

            <!-- Certificates -->
            <section class="cv-section cv-block">
              <h2 class="cv-h">Certificates<span class="cv-accent">.</span></h2>
              <ul class="cv-certs">
                {
                  certificates.map((cert) => (
                    <li>
                      <span class="cv-dot" aria-hidden="true" />
                      {cert}
                    </li>
                  ))
                }
              </ul>
            </section>

            <!-- Volunteering -->
            <section class="cv-section cv-block">
              <h2 class="cv-h">Volunteering<span class="cv-accent">.</span></h2>
              <div class="cv-vol">
                <div class="cv-vol-item">
                  <div class="cv-job-head">
                    <h3 class="cv-job-company">Ajungem Mari</h3>
                    <p class="cv-job-meta">10/2016 – 10/2017</p>
                  </div>
                  <p class="cv-job-role">Coordinator Member</p>
                  <p class="cv-body" style="margin-top: 4px;">
                    Educational program for children from foster care and disadvantaged backgrounds.
                  </p>
                </div>
                <div class="cv-vol-item">
                  <div class="cv-job-head">
                    <h3 class="cv-job-company">SiSC — Students Union of Cybernetics</h3>
                    <p class="cv-job-meta">11/2015 – 11/2016</p>
                  </div>
                  <p class="cv-job-role">IT Department Member</p>
                </div>
              </div>
            </section>
          </div>

        </div>
      </div>
    </div>
  </main>
  <div class="no-print">
    <Footer />
  </div>
</Layout>

<script>
  document.getElementById("print-cv")?.addEventListener("click", () => {
    window.print();
  });
</script>

<style>
  /* ============================================================
     SCREEN — the CV as a document preview on the site background
     ============================================================ */

  .cv-sheet {
    display: grid;
    grid-template-columns: 28% 72%;
    background: var(--bg2);
    border: 1px solid var(--white-icon-tr);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.08);
  }

  /* ---------- Sidebar ---------- */

  .cv-side {
    background: var(--background);
    border-right: 1px solid var(--white-icon-tr);
    padding: 44px 28px;
  }
  .cv-side-inner {
    position: sticky;
    top: 96px;
  }
  .cv-portrait {
    width: 112px;
    height: 112px;
    object-fit: cover;
    border-radius: 50%;
    border: 1px solid var(--white-icon-tr);
    margin-bottom: 16px;
  }
  .cv-side-name {
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .cv-side-role {
    font-size: 12.5px;
    color: var(--white-icon);
    margin-top: 2px;
  }
  .cv-tagline {
    font-family: var(--mono, monospace);
    font-size: 11px;
    letter-spacing: 0.03em;
    color: var(--sec2);
    margin-top: 8px;
  }
  .cv-rule {
    border: none;
    border-top: 1px solid rgba(196, 180, 154, 0.45);
    margin: 22px 0;
  }

  .cv-contact {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cv-contact li {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    font-size: 12px;
    line-height: 1.5;
    color: var(--white);
    font-family: var(--mono, monospace);
    letter-spacing: -0.01em;
    overflow-wrap: anywhere;
  }
  .cv-contact svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--sec2);
  }
  .cv-contact a {
    color: var(--white);
    text-decoration: none;
  }
  .cv-contact a:hover {
    text-decoration: underline;
    text-decoration-color: var(--sec);
    text-underline-offset: 3px;
  }

  .cv-side-label {
    font-family: var(--mono, monospace);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sec2);
    margin-bottom: 8px;
  }
  .cv-skills {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cv-chips {
