<style is:global>
  /* ============================================================
     PRINT — professionally typeset A4 document
     @page margin is 0 so the browser has no room to inject
     URL / date / page-number headers and footers; the document
     manages its own margins.
     ============================================================ */

  @media print {
    @page {
      size: A4;
      margin: 0;
    }

    nav,
    footer,
    .no-print,
    #main-nav {
      display: none !important;
    }

    html, body {
      width: 210mm;
    }

    body {
      background: #fff !important;
      padding: 0 !important;
      color: #111 !important;
    }

    /* the site's grid overlay hurts print readability — remove */
    body::after {
      display: none !important;
    }

    * {
      animation: none !important;
      transition: none !important;
      box-shadow: none !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

  }
</style>
