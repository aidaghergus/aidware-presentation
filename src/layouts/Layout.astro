---
interface Props {
  title: string;
  description?: string;
  ogType?: string;
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description = "aidware builds production-ready AI applications, backend systems and tailored software for legal and real estate businesses.",
  ogType = "website",
  structuredData,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/me2.png", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="aidware" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    {structuredData && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body class="bg-[--background] sm:px-28 lg:px-20 px-9">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --background: #f5f3ef;
    --bg2:        #ffffff;
    --bg3:        #ede9e2;
    --sec:        #c4b49a;
    --sec2:       #a89880;
    --sec-dim:    rgba(196,180,154,0.15);
    --white:      #111111;
    --white-icon: #6e675f;
    --white-icon-tr: #d8d2c8;
    --mono:       'JetBrains Mono', monospace;
  }

  * {
    font-family: 'Space Grotesk', -apple-system, system-ui, sans-serif;
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--background);
    color: var(--white);
    overflow-x: hidden;
  }

  /* square grid overlay */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(#c4b49a 1px, transparent 1px),
      linear-gradient(90deg, #c4b49a 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.22;
    pointer-events: none;
    z-index: -1;
  }

  *::selection {
    background-color: var(--sec);
    color: #fff;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--background); }
  ::-webkit-scrollbar-thumb { background: var(--white-icon-tr); border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--sec); }
  * { scrollbar-width: thin; scrollbar-color: var(--white-icon-tr) var(--background); }

  /* Reveal animation */
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }

  /* Section heading pattern */
  .section-eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sec2);
    margin-bottom: 8px;
  }

  /* Buttons */
  .btn-primary {
    background: var(--white);
    color: var(--background);
    padding: 10px 22px;
    border-radius: 8px;
    font-family: var(--mono, monospace);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-primary:hover { background: #333; transform: translateY(-2px); }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    padding: 10px 22px;
    border-radius: 8px;
    font-family: var(--mono, monospace);
    font-size: 13px;
    text-decoration: none;
    border: 1px solid var(--white-icon-tr);
    letter-spacing: 0.05em;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-secondary:hover { border-color: var(--white); transform: translateY(-2px); }

  .social-icon-btn {
    color: var(--white-icon);
    transition: color 0.2s, background 0.2s, border-color 0.2s;
    border: 1px solid var(--white-icon-tr);
    padding: 10px;
    border-radius: 10px;
    background: var(--bg2);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }
  .social-icon-btn:hover { color: var(--white); border-color: var(--white); }

  .shiny-sec {
    background: linear-gradient(135deg, var(--sec) 20%, var(--sec2) 50%, var(--sec) 80%);
    background-size: 400% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 3s linear infinite;
  }
  @keyframes shine {
    0%   { background-position: 100% 50%; }
    30%, 70% { background-position: 0% 50%; }
  }

  /* Terminal — stays dark intentionally */
  .terminal-box {
    background: #111111;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    max-width: 680px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  .terminal-bar {
    background: #1e1e1e;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid #2a2a2a;
  }
  .dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
  .terminal-title { font-size: 11px; color: #888880; margin-left: 6px; letter-spacing: 0.05em; font-family: var(--mono, monospace); }
  .terminal-body { padding: 20px 24px; font-family: var(--mono, monospace); font-size: 14px; line-height: 2; }
  .t-prompt { color: var(--sec); }
  .t-cmd    { color: #f0ece4; }
  .t-out    { color: #888880; display: block; }
  .t-green  { color: var(--sec); display: block; }
  .t-cursor { display: inline-block; width: 8px; height: 13px; background: var(--sec); vertical-align: middle; margin-left: 2px; }
</style>